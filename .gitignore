# ============================================
# Asmara.Store - .gitignore
# المنصة الرقمية المتكاملة لإريتريا
# الإصدار: 2.0
# ============================================

# -------------------------------
# Node.js / JavaScript
# -------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# -------------------------------
# Build / Distribution
# -------------------------------
build/
dist/
out/
.next/
.nuxt/
.vuepress/dist/
.vercel/
.vercel/output/

# -------------------------------
# Coverage / Testing
# -------------------------------
coverage/
.nyc_output/
*.lcov
jest.config.js
*.test.js
*.spec.js

# -------------------------------
# Environment Variables
# -------------------------------
.env
.env.*
!.env.example
.env.local
.env.production
.env.development

# -------------------------------
# IDE / Editor Files
# -------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.editorconfig
.eslintrc*
.prettierrc*
.stylelintrc*

# -------------------------------
# OS Generated Files
# -------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
*.tmp
*.temp

# -------------------------------
# Project Specific
# -------------------------------
# Logs
logs/
*.log
*.log.*

# Cache
.cache/
.parcel-cache/
.temp/

# Uploaded Images (Local)
uploads/
images/temp/
images/cache/
assets/images/uploads/

# Database
*.db
*.sqlite
*.sqlite3

# Backup files
*.bak
*.backup
*.old

# SSL Certificates (local)
*.pem
*.key
*.crt

# -------------------------------
# Authentication & Security
# -------------------------------
*.p12
*.pfx
.secrets/
secrets.json
credentials.json

# -------------------------------
# Temporary & User Data
# -------------------------------
*.log
*.pid
*.seed
*.pid.lock
.port
*.tar.gz
*.rar
*.7z

# -------------------------------
# Vercel Specific
# -------------------------------
.vercel
.vercel/output
.vercel/project.json

# -------------------------------
# User uploaded images (keep structure)
# -------------------------------
images/ads/**/*.jpg
images/ads/**/*.png
images/ads/**/*.jpeg
images/ads/**/*.webp
images/users/avatars/*.jpg
images/users/avatars/*.png
!images/ads/.gitkeep
!images/users/avatars/.gitkeep

# -------------------------------
# Reports & Logs (keep structure)
# -------------------------------
reports/**/*.xlsx
reports/**/*.csv
reports/**/*.pdf
!reports/.gitkeep
!logs/.gitkeep

# -------------------------------
# Documentation (optional)
# -------------------------------
docs/_build/
docs/api/

# -------------------------------
# Social Media / Images (local)
# -------------------------------
*.psd
*.ai
*.sketch
*.xd

# -------------------------------
# Docker (if used)
# -------------------------------
*.dockerignore
Dockerfile.dev

# -------------------------------
# GitHub specific
# -------------------------------
.github/FUNDING.yml
.github/ISSUE_TEMPLATE/

# -------------------------------
# Archive / Old files
# -------------------------------
*.zip
*.rar
*.7z
archive/
old/
deprecated/

# -------------------------------
# Local development
# -------------------------------
*.local
localhost.*
*.local.css
*.local.js

# -------------------------------
# Note: Keep these files in repo
# -------------------------------
# !.env.example
# !.gitkeep
# !.github/
# !README.md
# !index.html
